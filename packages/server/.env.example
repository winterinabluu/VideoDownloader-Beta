PORT=3000
NODE_ENV=development

# Optional cookies or tokens for platform access
YOUTUBE_COOKIES=
BILIBILI_COOKIE=
TWITTER_COOKIE=
WEIBO_COOKIE=
DOUYIN_COOKIE=
XIAOHONGSHU_COOKIE=

# Optional binary paths
YTDLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg

# Download settings
DOWNLOAD_CACHE_TTL_SECONDS=600
MAX_DOWNLOAD_SIZE_MB=2048

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
